# Optional. If unset, the server uses embedded PostgreSQL (~/.paperclip/instances/default/db).
# If set, use this same URL for pnpm db:migrate. Postgres must be running (e.g. docker compose up -d db).
# DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false
# Required by docker-compose when parsing (even for `docker compose up -d db`). Use a long random string in production.
BETTER_AUTH_SECRET=dev-secret-at-least-32-chars-long

# Security (optional). See doc/SECURITY.md.
# CORS_ORIGINS=https://app.example.com
# HSTS_MAX_AGE_SECS=31536000
