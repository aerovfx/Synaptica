# Leave DATABASE_URL unset for local dev → app uses embedded PostgreSQL (no install needed).
# Or set to your Postgres URL (user/database name is up to you), e.g.:
# DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
# DATABASE_URL=postgres://paperclip1:YOUR_PASSWORD@localhost:5432/paperclip1
PORT=3100
SERVE_UI=false
DATABASE_URL=postgres://paperclip1:YOUR_PASSWORD@localhost:5432/paperclip1